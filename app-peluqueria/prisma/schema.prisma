// Generador para poder usar Prisma en tu código
generator client {
  provider = "prisma-client-js"
}

// Conexión a tu base de datos MySQL
datasource db {
  provider = "mysql"
 
}

// --- TUS TABLAS DE DATOS ---

// Tabla para los servicios de tu peluquería
model Servicio {
  id          Int      @id @default(autoincrement())
  nombre      String   
  descripcion String?  
  precio      Float    
}